{
  "name": "naukri-automation",
  "version": "1.0.0",
  "description": "Incremental Playwright Test automation framework for Naukri.",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "test": "playwright test",
    "test:jobs": "playwright test tests/jobs",
    "test:jobs:headed": "playwright test tests/jobs/searchAndApply.spec.js --headed",
    "test:nvites": "playwright test tests/notifications/processNvites.spec.js",
    "test:nvites:headed": "playwright test tests/notifications/processNvites.spec.js --headed",
    "test:recommendations": "playwright test tests/recommendations/processRecommendations.spec.js",
    "test:recommendations:headed": "playwright test tests/recommendations/processRecommendations.spec.js --headed",
    "test:full": "playwright test tests/recommendations/processRecommendations.spec.js",
    "test:full:headed": "playwright test tests/recommendations/processRecommendations.spec.js --headed",
    "test:profile": "playwright test tests/profile",
    "test:profile:headed": "playwright test tests/profile/updateProfile.spec.js --headed",
    "test:resume": "playwright test tests/profile/updateResume.spec.js",
    "test:resume:headed": "playwright test tests/profile/updateResume.spec.js --headed",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report reports/html-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "patch-package": "^8.0.1"
  }
}
